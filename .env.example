PORT=
MONGODB_URI=
AUTH_PROVIDER=firebase
# Firebase Admin SDK credentials (from the service account key, no file checked in)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the \n escape sequences literal (single line); the app restores real newlines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_SECRET=
VITRINA_API_KEY=
# CORS — comma-separated list of allowed origins
# Example: http://localhost:3007,https://lifesyncgames.interaction-lab.info
CORS_ORIGINS=http://localhost:3007

# OAuth Providers
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_CALLBACK_URL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/oauth/github/callback